# ============================================================
# SAFE TO EXPOSE — these are embedded in the browser bundle
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/profile
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/profile/setup

NEXT_PUBLIC_SITE_URL=https://youreditorial.com
NEXT_PUBLIC_SITE_NAME=The Edit

# ============================================================
# SERVER-ONLY — NEVER prefix these with NEXT_PUBLIC_
# Exposing these bypasses all security (RLS, auth, etc.)
# ============================================================

# Supabase service role — bypasses RLS, server/webhooks only
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clerk secret — used to verify sessions server-side
CLERK_SECRET_KEY=sk_live_...

# Clerk webhook secret — used to verify svix signatures
CLERK_WEBHOOK_SECRET=whsec_...

# Upstash Redis — used for rate limiting and MusicBrainz cache
UPSTASH_REDIS_REST_URL=https://xxxxxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxx

# MusicBrainz: your site URL is used as the User-Agent contact
# No API key needed — just fill in your real site URL above
